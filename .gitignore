# Root GitIgnore for Monorepo (Laravel + Vite/React)

# OS Files
.DS_Store
Thumbs.db
*.log

# Environment Files
.env
.env.backup
.env.production
.env.local

# Build/Artifacts
/public/storage
/public/build
/public/hot
dist/

# Dependencies
node_modules/
vendor/

# Laravel Specific
backend/.env
backend/storage/*.key
backend/storage/framework/cache/data/*
backend/storage/framework/sessions/*
backend/storage/framework/testing/*
backend/storage/framework/views/*
backend/storage/logs/*
backend/vendor/
backend/node_modules/
backend/public/storage
backend/public/build
backend/public/hot
backend/artisan.php
backend/dmc-key.pem

# Frontend Specific
frontend/.env
frontend/node_modules/
frontend/dist/

# IDE
.vscode/
.idea/
.claude/
.agent/

# Temp/Debug
debug_*.php
error_log.txt
lint_errors.txt
lint_output.txt
fix_perms.ps1
git_status_output.txt
